msgstr "Du kan redigere beskeder, der bruges i forskellige situationer, her. For detaljer, se <a href=\"%s\">Redigering af beskeder</a>."

#. translators: %s: URL to support page about the email template
#: admin/includes/editor.php:207
msgid "You can edit the email template here. For details, see <a href=\"%s\">Setting up mail</a>."
msgstr "Du kan redigere e-mailskabelonen her. For detaljer, se <a href=\"%s\">Opsætning af post</a>."

